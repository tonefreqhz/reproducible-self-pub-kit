# Reproducible line endings across OSes
* text=auto eol=lf

# PowerShell scripts: keep LF in repo (works fine in PS 5.1/7)
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Markdown/docs
*.md  text eol=lf
*.txt text eol=lf

# Windows command files (if you ever add them)
*.bat text eol=crlf
*.cmd text eol=crlf
